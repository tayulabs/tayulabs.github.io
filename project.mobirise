    "sentinel85-lorawan.html": {
      "settings": {
        "title": "LoRaWAN Industrial RS485 Node",
        "order": "4",
        "meta_descr": "Nodo IoT industrial con ESP32-S3 y comunicación RS485 diseñado para integrar dispositivos Modbus a redes LoRaWAN. Soporta alimentación de 5–30VDC, conectividad WiFi y Bluetooth, ideal para monitoreo y control remoto en aplicaciones industriales, energéticas y agrícolas."
      },
      "components": [
        {
