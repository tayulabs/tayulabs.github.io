            ".item-wrapper": {
              "margin-bottom": "2rem",
              "background": "@cardColor",
              "padding": "1rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              },
              "@media (min-width: 768px)": {
                "padding": "2rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "margin-bottom": "3rem"
              }
            },
            ".mbr-section-title, .mbr-section-subtitle": {
