    "monitoreo-inteligente-gps.html": {
      "settings": {
        "title": "Monitoreo Inteligente para tus Vacas.",
        "order": "8",
        "meta_descr": "Monitorea la ubicación de tu ganado en tiempo real y visualiza los datos desde la plataforma IoT, mejorando la gestión y control del rebaño de manera eficiente y segura."
      },
      "components": [
        {
